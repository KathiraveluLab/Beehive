# Beehive Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# MongoDB Configuration
MONGODB_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_URI=mongodb://localhost:27017/
DATABASE_NAME=beehive

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_API_KEY=your_google_api_key_here
REDIRECT_URI=http://localhost:5000/admin/login/callback

# Flask Configuration
FLASK_SECRET_KEY=your_flask_secret_key_here

# Rate Limiting
# Production: RATE_LIMIT_STORAGE_URL
# Development (single worker only): RATE_LIMIT_STORAGE_URI=memory://
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_STORAGE_URI=redis://redis:6379/0
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_ANALYZE_MEDIA=20/minute
RATE_LIMIT_CHAT_SEND=60/minute
RATE_LIMIT_CHAT_MESSAGES=120/minute
RATE_LIMIT_EDIT_DELETE=30/minute
RATE_LIMIT_NOTIFICATIONS=60/minute
RATE_LIMIT_GET_UPLOADS=60/minute

# Clerk Authentication Configuration
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Admin Configuration
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Environment Setting (for OAuth in development)
OAUTHLIB_INSECURE_TRANSPORT=1